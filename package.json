{
	"name": "obsidian-custom-sort",
	"version": "3.1.6",
	"description": "Custom Sort plugin for Obsidian (https://obsidian.md)",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "jest"
	},
	"keywords": [
		"obsidian",
		"custom sorting"
	],
	"author": "SebastianMC",
	"repository": "https://github.com/SebastianMC/obsidian-custom-sort",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/jest": "^28.1.2",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint": "^8.29.0",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jest": "^29.7.0",
		"jiti": "2.6.1",
		"monkey-around": "^3.0.0",
		"obsidian": "^1.7.2",
		"ts-jest": "^29.2.5",
		"tslib": "2.8.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"volta": {
		"node": "24.14.0",
		"pnpm": "8.12.1",
		"yarn": "1.22.22"
	},
	"dependencies": {
		"tern": "^0.24.3"
	}
}
